# ─── Auth Mode ───────────────────────────────────────
# "mock" for local dev, "entra" for production
VITE_AUTH_MODE=mock
AUTH_MODE=mock

# ─── Backend ─────────────────────────────────────────
PORT=4000
DATABASE_URL="sqlserver://localhost:1433;database=portal_aegea;user=sa;password=YourStrong!Pass;encrypt=true;trustServerCertificate=true"

# ─── Mock Auth (dev only) ────────────────────────────
MOCK_JWT_SECRET=dev-secret-key-change-in-production

# ─── Microsoft Entra ID (production) ─────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=
VITE_AZURE_REDIRECT_URI=http://localhost:3000

# ─── Frontend ────────────────────────────────────────
VITE_API_URL=http://localhost:4000/api/v1
