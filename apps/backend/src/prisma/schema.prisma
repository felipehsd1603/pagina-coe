generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────

enum AppCategory {
  OPERACIONAL
  COMERCIAL
  CORPORATIVO
  FINANCEIRO
  ENGENHARIA
  RH
  SUSTENTABILIDADE
  TI
}

enum AppPhase {
  IDEACAO
  DESENVOLVIMENTO
  HOMOLOGACAO
  PRODUCAO
  DESATIVADO
}

enum AppClassification {
  CRITICAL
  STANDARD
  LOW
}

enum AppDirective {
  SCALE
  MAINTAIN
  RETIRE
  EVALUATE
}

enum QualLevel {
  OURO
  PRATA
  BRONZE
  SEM_CLASSIFICACAO
}

enum DemandPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DemandStatus {
  PENDING
  IN_REVIEW
  APPROVED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum UserRole {
  USER
  ADMIN
}

enum CitizenTier {
  T1
  T2
  T3
  T4
}

// ─── Models ──────────────────────────────────────────────────

model App {
  id              String            @id @default(uuid())
  name            String
  slug            String            @unique
  description     String            @db.NVarChar(Max)
  shortDescription String?          @db.NVarChar(500)
  category        AppCategory
  phase           AppPhase
  classification  AppClassification @default(STANDARD)
  directive       AppDirective      @default(MAINTAIN)
  qualLevel       QualLevel         @default(SEM_CLASSIFICACAO)
  owner           String?
  ownerEmail      String?
  regional        String?
  environment     String?
  iconUrl         String?
  bannerUrl       String?
  appUrl          String?
  usersCount      Int               @default(0)
  sessionsMonth   Int               @default(0)
  published       Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  benefits     AppBenefit[]
  documents    AppDocument[]
  metrics      AppMetric[]
  relatedFlows RelatedFlow[]
  testimonials Testimonial[]

  @@map("apps")
}

model AppBenefit {
  id    String @id @default(uuid())
  appId String
  title String
  description String? @db.NVarChar(500)

  app App @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@map("app_benefits")
}

model AppDocument {
  id    String @id @default(uuid())
  appId String
  title String
  url   String
  type  String? // PDF, LINK, VIDEO

  app App @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@map("app_documents")
}

model AppMetric {
  id    String @id @default(uuid())
  appId String
  label String
  value String
  icon  String?

  app App @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@map("app_metrics")
}

model RelatedFlow {
  id    String @id @default(uuid())
  appId String
  name  String
  type  String? // Power Automate, Power BI, etc.

  app App @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@map("related_flows")
}

model Testimonial {
  id         String   @id @default(uuid())
  appId      String?
  authorName String
  authorRole String?
  authorArea String?
  content    String   @db.NVarChar(Max)
  rating     Int      @default(5)
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())

  app App? @relation(fields: [appId], references: [id], onDelete: SetNull)

  @@map("testimonials")
}

model Demand {
  id             String         @id @default(uuid())
  title          String
  description    String         @db.NVarChar(Max)
  requesterName  String
  requesterEmail String
  area           String
  priority       DemandPriority @default(MEDIUM)
  status         DemandStatus   @default(PENDING)
  adminNotes     String?        @db.NVarChar(Max)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@map("demands")
}

model GlobalMetric {
  id    String @id @default(uuid())
  key   String @unique
  label String
  value String
  icon  String?

  @@map("global_metrics")
}

model Course {
  id          String      @id @default(uuid())
  title       String
  description String      @db.NVarChar(Max)
  tier        CitizenTier
  url         String?
  durationMin Int         @default(0)
  provider    String?
  published   Boolean     @default(true)
  createdAt   DateTime    @default(now())

  @@map("courses")
}

model User {
  id       String   @id @default(uuid())
  entraId  String   @unique
  email    String   @unique
  name     String
  role     UserRole @default(USER)
  createdAt DateTime @default(now())

  @@map("users")
}
